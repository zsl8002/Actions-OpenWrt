# This is an empty file, please overwrite it after generating the .config file with the source code#
# 编译配置示例 (x86_64 通用版)
# 请根据你的路由器架构修改 TARGET 相关配置
#

# 目标架构架构 (这里以 x86_64 为例，通用PC/大部分软路由)
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y

# 禁用旧式构建系统
CONFIG_CLEAN_IPKG=y
# CONFIG_SIGN_PACKAGE is not set

# ===== 基础系统配置 =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_block-mount=y

# ===== 必装核心插件 (根据上面的diy-part2.sh选择) =====
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-mosdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-app-adguardhome=y

# ===== 主题设置 =====
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# ===== 基础工具 =====
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_bash=y

# ===== 其他推荐设置 (可选) =====
# 开启 ZRAM 压缩内存 (低内存路由器必备)
# CONFIG_PACKAGE_kmod-zram=y
# CONFIG_PACKAGE_zram-swap=y
